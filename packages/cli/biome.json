{
  "$schema": "https://biomejs.dev/schemas/2.0.0/schema.json",
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "error"
      },
      "style": {
        "useConst": "error",
        "noNonNullAssertion": "info"
      }
    }
  },
  "formatter": {
    "enabled": false
  },
  "files": {
    "includes": ["src/**/*.ts", "tests/**/*.ts"]
  }
}
