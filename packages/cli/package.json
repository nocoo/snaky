{
  "name": "@nocoo/snaky",
  "version": "0.1.0",
  "description": "IP routing probe & latency tester",
  "type": "module",
  "bin": {
    "snaky": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ip",
    "probe",
    "latency",
    "routing",
    "vpn",
    "split-tunnel"
  ],
  "author": "nocoo",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^3.2.1",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
